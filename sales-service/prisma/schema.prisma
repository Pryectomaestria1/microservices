generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  courseIds     String[]
  amount        Float
  paymentMethod String   @default("Credit Card")
  cardEnding    String   @default("****")
  cardHolder    String?
  status        String   @default("Completed")
  createdAt     DateTime @default(now())
}
